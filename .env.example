# ============================================================================
# API CONFIGURATION
# ============================================================================
WORKER_API_URL=http://localhost:5000
WORKER_API_KEY=your_api_key_here

# ============================================================================
# HUGGING FACE & LLM
# ============================================================================
HF_TOKEN=your_hf_token_here
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# ============================================================================
# LTX VIDEO GENERATION
# ============================================================================
# Working Space: Lipetomasz/LTX2.3-StudioMojegowno
LTX_SPACE_ID=Lipetomasz/LTX2.3-StudioMojegowno
VIDEO_STEPS=20
VIDEO_HEIGHT=480
VIDEO_WIDTH=480
VIDEO_SEED=42

# ============================================================================
# COST OPTIMIZATION & CACHING
# ============================================================================
# Global prompt/video cache TTL (seconds)
CACHE_TTL_SECONDS=86400

# Gemini prompt generation cache
GEMINI_CACHE_ENABLED=true
GEMINI_CACHE_TTL_HOURS=24

# Video generation deduplication by prompt hash
VIDEO_CACHE_ENABLED=true
VIDEO_CACHE_TTL_HOURS=168

# Audio TTS cache (Piper)
AUDIO_CACHE_ENABLED=true
AUDIO_CACHE_TTL_HOURS=168

# Shared prompt database (Redis optional, falls back to SQLite)
CACHE_BACKEND=sqlite  # Options: sqlite, redis
REDIS_URL=redis://localhost:6379/0
CACHE_DB_PATH=./cache/optimization.db

# ============================================================================
# RETRY & QUOTA MANAGEMENT
# ============================================================================
MAX_RETRIES=5
RETRY_DELAY_SECONDS=10
QUEUE_CHECK_INTERVAL=5
MAX_QUEUE_WAIT_SECONDS=600

# Quota burst protection
QUOTA_BACKOFF_MULTIPLIER=2.0
QUOTA_INITIAL_WAIT_SECONDS=60
QUOTA_MAX_WAIT_SECONDS=3600

# ============================================================================
# CONCURRENCY & BATCH PROCESSING
# ============================================================================
# CRITICAL: Set to 1 for maximum efficiency (prevent GPU quota waste)
MAX_CONCURRENT_JOBS=1

# Batch job processing (accumulate requests, process in bulk)
BATCH_PROCESSING_ENABLED=true
BATCH_TIMEOUT_SECONDS=300
BATCH_MIN_SIZE=3

# ============================================================================
# OUTPUT & STORAGE
# ============================================================================
OUTPUT_DIR=./output
CACHE_DIR=./cache
LOG_LEVEL=INFO
LOG_FILE=./logs/ltx_automation.log

# Storage cleanup (minutes)
STORAGE_CLEANUP_INTERVAL_MINUTES=360
STORAGE_RETENTION_HOURS=168

# ============================================================================
# MONITORING & METRICS
# ============================================================================
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=8000
METRICS_COLLECTION_ENABLED=true
METRICS_DB_PATH=./cache/metrics.db

# ============================================================================
# WEBHOOK
# ============================================================================
WEBHOOK_URL=https://your-webhook-url.com/webhook
WEBHOOK_RETRY_ENABLED=true
WEBHOOK_RETRY_COUNT=3
