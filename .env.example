# CashMaker VEO Worker API Configuration
# Copy this to .env and fill in your values

# API Configuration
WORKER_API_URL=https://web-production-46f9e.up.railway.app
WORKER_API_KEY=your_api_key_here

# Hugging Face
HF_TOKEN=your_hf_token_here

# LTX Video Settings
LTX_SPACE_ID=Lightricks/LTX-2-3
VIDEO_DURATION_SECONDS=10
NUM_FRAMES=240
VIDEO_STEPS=20
VIDEO_HEIGHT=480
VIDEO_WIDTH=480

# Retry Configuration
MAX_RETRIES=5
RETRY_DELAY_SECONDS=10
QUEUE_CHECK_INTERVAL=5
MAX_QUEUE_WAIT_SECONDS=600

# Output
OUTPUT_DIR=./output
LOG_LEVEL=INFO

# Webhook (optional - for receiving callbacks from CashMaker)
WEBHOOK_URL=https://your-domain.com/webhook

# Optional: CashMaker render settings
ENABLE_AUTO_RETRY=true
AUTO_RETRY_MAX_ATTEMPTS=3
AUTO_RETRY_INITIAL_DELAY=30

# Optional: Hashtags to use with renders (comma-separated or JSON array in code)
DEFAULT_HASHTAGS=#finanse #inwestycje #oszczedzanie
